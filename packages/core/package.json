{
  "name": "llmwiki-core",
  "version": "0.1.0",
  "description": "Headless LLM Wiki engine core — pure deterministic logic plus pluggable LLM ops.",
  "type": "module",
  "license": "MIT",
  "author": "llmwiki contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Edisonzszs/llmwiki.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Edisonzszs/llmwiki#readme",
  "bugs": { "url": "https://github.com/Edisonzszs/llmwiki/issues" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9"
  },
  "engines": { "node": ">=20" },
  "keywords": ["llm", "wiki", "knowledge-base", "rag", "karpathy", "markdown", "personal-knowledge", "memex", "second-brain"]
}
