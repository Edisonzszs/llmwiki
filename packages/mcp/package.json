{
  "name": "llmwiki-mcp",
  "version": "0.1.0",
  "description": "MCP server for the LLM Wiki engine — drive it from Claude Code / Codex / any MCP client.",
  "type": "module",
  "license": "MIT",
  "author": "llmwiki contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Edisonzszs/llmwiki.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/Edisonzszs/llmwiki#readme",
  "bugs": { "url": "https://github.com/Edisonzszs/llmwiki/issues" },
  "bin": {
    "llmwiki-mcp": "./dist/server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "llmwiki-core": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "engines": { "node": ">=20" },
  "keywords": ["llm", "wiki", "knowledge-base", "mcp", "model-context-protocol", "claude-code", "rag"]
}
